# Gatus Config Editor — Environment Variables
# Copy this file to .env and update all values before deploying.

# Port for the web UI
APP_PORT=8080

# Path to the Gatus config file or directory inside the container
GATUS_CONFIG_PATH=/config/config.yaml

# Docker container name for the Gatus instance to manage
GATUS_CONTAINER_NAME=gatus

# Admin credentials — CHANGE THESE BEFORE STARTING
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Secret used to sign session cookies — CHANGE THIS BEFORE STARTING
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-with-a-random-64-char-hex-string

# Directory where config backups are stored (inside the container)
BACKUP_DIR=/config/backups

# Allow the UI to restart the Gatus container via Docker socket
ALLOW_DOCKER_RESTART=true

# Internal URL to reach the Gatus container (used to proxy its status API)
GATUS_API_URL=http://gatus:8080

# Set to true to disable all config modifications (read-only UI)
READ_ONLY_MODE=false

# Security — set HTTPS_ONLY=true when running behind a TLS reverse proxy
HTTPS_ONLY=false

# CSRF protection — disable only for testing
CSRF_ENABLED=true

# Allowed CORS origins (comma-separated). Empty = no CORS headers (safe for prod).
# For local dev with Vite proxy this is not needed.
# CORS_ORIGINS=http://localhost:5173

# Development escape hatch only. Leave false/empty in production.
# ALLOW_INSECURE_DEFAULTS=false
